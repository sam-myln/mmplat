// Main page template. Implements BasePage methods.
{% code
type Render struct {
    File map[string]string
}
%}


{% func (p *Render) Head() %}
<!-- // video[path|type]string -->
<head>
    <!-- TODO replace w/ asset directory provided by handler or whatever -->
    <!--  also add integrity check during application start(bootstrap) -->
    <title>Media player</title>
    <link rel="stylesheet" href="../../assets/videojs/video-js.css">
    <link rel="stylesheet" href="../../assets/videojs/videojs-http-source-selector.css">
    <link rel="stylesheet" href="../../assets/videojs/videojs.markers.css">
    <link rel="stylesheet" href="../../assets/videojs/videojs-share.css">
    <link rel="stylesheet" href="../../assets/videojs/videojs-vtt-thumbnails.css">
    <link rel="stylesheet" href="../../assets/videojs/videojs-mobile-ui.css">
    <link rel="stylesheet" href="../../assets/css/player.css">

    <script src="../../assets/videojs/video.js"></script>
    <script src="../../assets/videojs/videojs-mobile-ui.js"></script>
    <script src="../../assets/videojs/videojs-contrib-quality-levels.js"></script>
    <script src="../../assets/videojs/videojs-http-source-selector.js"></script>
    <script src="../../assets/videojs/videojs-markers.js"></script>
    <script src="../../assets/videojs/videojs-share.js"></script>
    <script src="../../assets/videojs/videojs-vtt-thumbnails.js"></script>
    <script src="../../assets/js/_helpers.js"></script>
    <link rel="icon" href="data:,">
</head>
{% endfunc %}

{% func (p *Render) Body() %}
<a href="?nojs">no js</a><br />
<script id="video_data" type="application/json">
