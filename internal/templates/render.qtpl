<div id="player-container" class="h-box">
    <video style="outline:none;width:100%;background-color:#000" playsinline poster="../../assets/images/cinema_image.png"
           id="player" class="on-video_player video-js player-style-invidious"
           autoplay
           controls>
        <source src='stream/{%s p.File["name"] %}' type='{%s p.File["type"] %}' hidequalityoption="true" selected="true">
